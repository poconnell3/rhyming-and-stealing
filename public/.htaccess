Options -MultiViews

RewriteEngine On

# Canonical domain and HTTPS.
# Enable this block only after SSL works correctly.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.rhymingandstealing\.com$ [NC]
RewriteRule ^ https://rhymingandstealing.com%{REQUEST_URI} [R=301,L]

# Allow real files, directories, and certificate challenges through.
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-l

# Send SPA routes to the application.
RewriteRule . /index.html [L]

# Avoid caching HTML so new releases are detected promptly.
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Vite and modern React builds normally hash these filenames.
  <FilesMatch "\.(js|css|woff2|png|jpg|jpeg|gif|svg|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
